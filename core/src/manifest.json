{
	"manifest_version": 3,
	"name": "Mithril Devtools",
	"description": "Easier debugging for mithril developers",
	"version": "0.0.1",
	"action": {
		"icons": {
			"16": "icons/icon16.png",
			"32": "icons/icon32.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"devtools_page": "main.html",
	"permissions": ["contextMenus"],
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["scripts/injection.js"],
			"run_at": "document_start",
			"world": "MAIN"
		},
		{
			"matches": ["<all_urls>"],
			"js": ["scripts/communicator.js"],
			"run_at": "document_start"
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["scripts/injection.js"],
			"matches": ["<all_urls>"]
		}
	]
}
